{
  "name": "kronometa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aplicacion web de cronometraje manual de carreras con PickComponents.",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "test:integration": "playwright test --project=firefox",
    "test:integration:all": "playwright test"
  },
  "dependencies": {
    "@janmbaco/injectkit": "1.2.0-jan.1",
    "pick-components": "^1.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.5.1",
    "typescript": "6.0.2",
    "vite": "8.0.8"
  },
  "packageManager": "npm@10"
}
